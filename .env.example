PRIMARY_API_KEY=your_primary_api_key_here
PRIMARY_MODEL=deepseek-v4-flash
PRIMARY_BASE_URL=https://api.deepseek.com/v1

MULTIMODAL_API_KEY=your_multimodal_api_key_here
MULTIMODAL_MODEL=your_multimodal_model
MULTIMODAL_BASE_URL=https://your-multimodal-provider.example/v1

WEB_SCREENSHOT_API_URL=https://snap.idsiber.com/api/screenshot

CONTEXT_OPTIMIZE=true
CONTEXT_OPTIMIZE_MODE=summary
AGENT_MAX_ITERATIONS=50
LLM_REQUEST_LOGGING=false

DATA_DIR=data
PORT=3000

# --- App / Auth ---
APP_URL=http://localhost:3000
SESSION_SECRET=
SESSION_MAX_AGE_DAYS=7
ADMIN_EMAILS=admin@example.com,other-admin@example.com
PASSWORD_MIN_LENGTH=8
VERIFICATION_TOKEN_HOURS=24

# --- Anonymous mode ---
ANON_PROJECT_LIMIT=3
ANON_MAX_AGE_DAYS=30

# --- Mail (SMTP sender) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=craft@idsiber.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=craft@idsiber.com
MAIL_FROM_NAME="Craft idSiber"
